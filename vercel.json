{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    { "src": "api/search.py", "use": "@vercel/python" },
    { "src": "api/item.py", "use": "@vercel/python" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/search", "dest": "api/search.py" },
    { "src": "/api/item",   "dest": "api/item.py" },
    { "src": "/(.*)",       "dest": "public/$1" }
  ]
}
